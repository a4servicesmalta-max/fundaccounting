# ── THCP Autopilot configuration ──────────────────────────────────────────────
# Copy this file to ".env" and fill in the values you need.

# Your Anthropic API key (get one at https://console.anthropic.com/).
# This is what lets the app read your documents with AI.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The AI model used to read documents. Leave this as-is unless told otherwise.
ANTHROPIC_MODEL=claude-opus-4-8

# The web address the app runs on locally. Open this in your browser after starting.
PORT=4350

# ── Storage ───────────────────────────────────────────────────────────────────
# 'file'     = books + uploads live on local disk (default; for your machine).
# 'supabase' = books blob lives in a Supabase table and uploads in Supabase
#              Storage (required for hosting on Vercel, whose disk is ephemeral).
STORAGE_DRIVER=file

# Only needed when STORAGE_DRIVER=supabase. From your Supabase project settings:
#   SUPABASE_URL          → Project Settings → API → Project URL
#   SUPABASE_SERVICE_KEY  → Project Settings → API → service_role secret key
#   SUPABASE_BUCKET       → the Storage bucket name (defaults to "documents")
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=documents

# ── Access (login gate) ───────────────────────────────────────────────────────
# Set APP_PASSWORD to require a shared password before the app can be used.
# Leave it blank for an open local instance. SESSION_SECRET signs the login
# cookie — use any long random string in production.
APP_PASSWORD=
SESSION_SECRET=

# The fund whose books these are — sets ACQUISITION vs DISPOSAL by the entity's side of an SPA.
REPORTING_ENTITY=Your Fund Legal Name Ltd
